# ======================
# AgentForge - HDB Resale Monitor
# ======================

# LLM API Keys (at least one required)
OPENAI_API_KEY=sk-your-openai-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
LLM_PROVIDER=openai  # "openai" or "anthropic"
LLM_MODEL=gpt-4o     # or "claude-sonnet-4-20250514"

# Bright Data - Web Scraping
BRIGHTDATA_API_TOKEN=your-brightdata-api-token

# ActionBook - Browser Automation
ACTIONBOOK_API_KEY=your-actionbook-api-key
ACTIONBOOK_BASE_URL=https://api.actionbook.dev

# Acontext - Agent Memory
ACONTEXT_API_KEY=your-acontext-api-key

# Database
DATABASE_URL=sqlite:///./agentforge.db

# App Settings
APP_HOST=0.0.0.0
APP_PORT=8000
FRONTEND_URL=http://localhost:5173
